services:
  socket-proxy:
    image: ghcr.io/tecnativa/docker-socket-proxy:{{ portainer_socket_proxy_version | default('0.3.0') }}
    container_name: toolkit-socket-proxy
    restart: unless-stopped
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro
    environment:
      - CONTAINERS=1
      - IMAGES=1
      - INFO=1
      - NETWORKS=1
      - SERVICES=1
      - TASKS=1
      - VOLUMES=1
      - VERSION=1
      - POST=1
      - BUILD=0
      - AUTH=0
      - SECRETS=0
      - SWARM=0
    networks:
      - socket_proxy_net

  portainer:
    image: portainer/portainer-ce:{{ portainer_version | default('2.21.4') }}
    container_name: portainer
    depends_on:
      - socket-proxy
    environment:
      DOCKER_HOST: tcp://socket-proxy:2375
    volumes:
      - portainer_data:/data
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy_network"
      - "traefik.http.routers.portainer.rule=Host(`{{ portainer_hostname }}`)"
      - "traefik.http.routers.portainer.entrypoints=websecure"
      - "traefik.http.routers.portainer.tls.certresolver=cloudflare"
      - "traefik.http.services.portainer.loadbalancer.server.port=9000"
    networks:
      - default
      - proxy_network
      - socket_proxy_net
    restart: unless-stopped

  netdata:
    image: netdata/netdata:{{ netdata_version | default('stable') }}
    container_name: netdata
    cap_add:
      - SYS_PTRACE
    security_opt:
      - apparmor:unconfined
    volumes:
      - /proc:/host/proc:ro
      - /sys:/host/sys:ro
      - /var/run/docker.sock:/var/run/docker.sock:ro
      - netdata_cache:/var/cache/netdata
      - netdata_lib:/var/lib/netdata
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy_network"
      - "traefik.http.routers.netdata.rule=Host(`{{ netdata_hostname }}`)"
      - "traefik.http.routers.netdata.entrypoints=websecure"
      - "traefik.http.routers.netdata.tls.certresolver=cloudflare"
      - "traefik.http.services.netdata.loadbalancer.server.port=19999"
    networks:
      - default
      - proxy_network
    restart: unless-stopped

  uptime-kuma:
    image: louislam/uptime-kuma:{{ uptime_kuma_version | default('1.23.16') }}
    container_name: uptime-kuma
    volumes:
      - uptime-kuma:/app/data
    labels:
      - "traefik.enable=true"
      - "traefik.docker.network=proxy_network"
      - "traefik.http.routers.uptime-kuma.rule=Host(`{{ uptime_kuma_hostname }}`)"
      - "traefik.http.routers.uptime-kuma.entrypoints=websecure"
      - "traefik.http.routers.uptime-kuma.tls.certresolver=cloudflare"
      - "traefik.http.services.uptime-kuma.loadbalancer.server.port=3001"
    networks:
      - default
      - proxy_network
    restart: unless-stopped

volumes:
  portainer_data:
  netdata_cache:
  netdata_lib:
  uptime-kuma:

networks:
  default:
    driver: bridge
  proxy_network:
    external: true
    name: proxy_network
  socket_proxy_net:
    driver: bridge
    internal: true
